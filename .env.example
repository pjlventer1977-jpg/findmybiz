# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# PayFast — use sandbox credentials only when PAYFAST_SANDBOX=true
PAYFAST_MERCHANT_ID=your-merchant-id
PAYFAST_MERCHANT_KEY=your-merchant-key
PAYFAST_PASSPHRASE=your-passphrase
PAYFAST_SANDBOX=false

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Find My Biz

# Google Maps (optional)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-key

# Email (Resend - optional)
RESEND_API_KEY=your-resend-api-key

# SMTP — lead notifications (mail.findmybiz.co.za)
# If mail subdomain CNAME points to Vercel, use cPanel IP + TLS servername:
SMTP_HOST=102.208.231.6
SMTP_TLS_SERVERNAME=mail.findmybiz.co.za
SMTP_PORT=465
SMTP_USER=leads@findmybiz.co.za
SMTP_PASSWORD=your-mailbox-password
SMTP_FROM_EMAIL=leads@findmybiz.co.za
SMTP_FROM_NAME=Find My Biz Leads

# Admin receives new business registration pending-approval alerts
ADMIN_APPROVAL_EMAIL=info@findmybiz.co.za
